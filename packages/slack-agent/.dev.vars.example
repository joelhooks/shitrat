# Copy to .dev.vars for local wrangler dev. Never commit real values.
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
JOELCLAW_EXECUTOR_URL=http://127.0.0.1:8789/shitrat/jobs
JOELCLAW_EXECUTOR_SECRET=
SHITRAT_REACTION_SUMMON=shitrat
SHITRAT_REACTION_SUMMON_ALIASES=rat
SHITRAT_REACTION_ACK=shitrat
SHITRAT_REACTION_WATCH=eyes
# Cloudflare AI Gateway / unified model prototype
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
SHITRAT_GATEWAY_MODEL=openai/gpt-5.5
# Optional: only needed if the gateway/provider is not using Cloudflare stored keys / unified billing.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
SHITRAT_GATEWAY_THINKING=off
CLOUDFLARE_AI_GATEWAY_ID=wizard-shit
